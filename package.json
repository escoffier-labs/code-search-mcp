{
  "name": "@solomonneas/code-search-mcp",
  "version": "0.2.0",
  "description": "Read-only MCP server and OpenClaw plugin for querying a local code-search-api index by intent.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "bin": {
    "code-search": "dist/cli.js",
    "code-search-mcp": "dist/mcp-bin.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/cli.js mcp",
    "smoke": "tsx scripts/smoke.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "pack:dry-run": "npm pack --dry-run",
    "release": "scripts/release.sh",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "author": "Solomon Neas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/escoffier-labs/code-search-mcp.git"
  },
  "homepage": "https://github.com/escoffier-labs/code-search-mcp#readme",
  "bugs": {
    "url": "https://github.com/escoffier-labs/code-search-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "code-search",
    "semantic-search",
    "ollama",
    "sqlite",
    "claude",
    "openclaw",
    "codex"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist",
    "index.mjs",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "openclaw": {
    "extensions": [
      "./index.mjs"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.4.27",
      "pluginSdkVersion": "2026.4.27"
    }
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
