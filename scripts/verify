#!/bin/bash
# Single verification entrypoint. AGENTS.md's Definition of Done defers to this
# file, so the gate lives in exactly one place.
set -euo pipefail
cd "$(dirname "$0")/.."

npm run typecheck
npm test
npm run build

# Conditional checks, not run here:
# - `npm run smoke` needs a live code-search-api on 5204 (run `npm run build` first).
# - `npm run pack:dry-run` is only required when changing the publish payload.
